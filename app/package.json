{
  "name": "keyward-passbook-app",
  "private": true,
  "version": "2.0.0",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "description": "Keyward Passbook \u2014 web vault (Vue 3 + Vite), backed by the passbook-wasm crypto core.",
  "scripts": {
    "build:wasm": "wasm-pack build --release --target web --out-dir \"$PWD/src/wasm/pkg\" ../crates/passbook-wasm",
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "tsx scripts/roundtrip.test.ts && tsx scripts/trust.test.ts",
    "tauri": "tauri"
  },
  "dependencies": {
    "pinia": "^2.2.6",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^22.20.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "tsx": "^4.23.0",
    "typescript": "~5.6.3",
    "vite": "^6.0.5",
    "vue-tsc": "^2.1.10"
  }
}
