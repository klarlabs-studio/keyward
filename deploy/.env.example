# Local Postgres credentials for deploy/docker-compose.pg.yml.
#
#   cp deploy/.env.example deploy/.env && $EDITOR deploy/.env
#
# Deliberately has no working default: compose fails if KEYWARD_DB_PASSWORD is
# unset. A default that works is a default that ships, and a password committed
# to an open-source repository is public the moment it is pushed.
#
# This file is for LOCAL DEVELOPMENT. In the managed deployment the value comes
# from a Kubernetes Secret (deploy/k8s), never from a file in the repo.
#
# Generate one:  openssl rand -base64 24
KEYWARD_DB_PASSWORD=
